{
  "name": "@kensio/smartass",
  "description": "TypeScript-first test assertion functions with precise type narrowing",
  "author": "Kensio Software",
  "repository": "https://github.com/KensioSoftware/smartass",
  "homepage": "https://smartassertions.dev/",
  "license": "Apache-2.0",
  "version": "1.31.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./eslint": {
      "types": "./dist/eslint/smartass-eslint.config.d.ts",
      "import": "./dist/eslint/smartass-eslint.config.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:check": "tsc -p tsconfig.json --noEmit",
    "build:index": "bash scripts/build-index.sh",
    "build:readme": "bash scripts/build-readme-lists.sh",
    "fmt": "eslint --fix . && prettier --write .",
    "lint": "eslint . && prettier --check .",
    "test": "vitest run --typecheck",
    "test:coverage": "vitest run --typecheck --coverage",
    "check": "pnpm fmt && pnpm build:check && pnpm test:coverage"
  },
  "keywords": [
    "test",
    "assertion",
    "type",
    "narrowing"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint-plugin-security": "^3.0.1",
    "@types/node": "^25.9.4",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^63.0.8",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
