{
  "name": "smartass",
  "version": "0.0.1",
  "description": "TypeScript-first test assertion functions with precise type narrowing",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "fmt": "eslint --fix '{src,test}/**/*.{ts,js}' && prettier --write '{src,test}/**/*.{ts,js,json,md,css,html,yml,yaml}'",
    "lint": "eslint '{src,test}/**/*.{ts,js}' && prettier --check '{src,test}/**/*.{ts,js,json,md,css,html,yml,yaml}'"
  },
  "keywords": [
    "test",
    "assertion",
    "narrowing"
  ],
  "author": "Kensio Software",
  "license": "AGPL-3.0",
  "packageManager": "pnpm@10.32.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint-plugin-security": "^3.0.1",
    "@types/node": "^25.4.0",
    "@vitest/eslint-plugin": "^1.6.10",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  }
}
