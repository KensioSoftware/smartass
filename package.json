{
  "name": "@kensio/smartass",
  "description": "TypeScript-first test assertion functions with precise type narrowing",
  "author": "Kensio Software",
  "repository": "https://github.com/KensioSoftware/smartass",
  "homepage": "https://smartassertions.dev/",
  "license": "Apache-2.0",
  "version": "1.34.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./eslint": {
      "types": "./dist/eslint/smartass-eslint.config.d.ts",
      "import": "./dist/eslint/smartass-eslint.config.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:check": "tsc -p tsconfig.json --noEmit",
    "build:index": "bash scripts/build-index.sh",
    "build:readme": "bash scripts/build-readme-lists.sh",
    "fmt": "eslint --fix . && prettier --write .",
    "lint": "eslint . && prettier --check .",
    "test": "vitest run --typecheck",
    "test:coverage": "vitest run --typecheck --coverage",
    "check": "pnpm fmt && pnpm build:check && pnpm test:coverage"
  },
  "keywords": [
    "test",
    "assertion",
    "type",
    "narrowing"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/eslint-plugin-security": "^3.0.1",
    "@types/node": "^25.9.5",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/eslint-plugin": "^1.6.22",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^63.0.12",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-unicorn": "^66.0.0",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "prettier": "^3.9.4",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
